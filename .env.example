# LLM Provider (ollama | bedrock | lmstudio | openrouter | openai | gemini | custom)
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.3:70b
OLLAMA_HOST=http://localhost:11434

# AWS Bedrock (only needed if DEFAULT_PROVIDER=bedrock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# LM Studio (only needed if DEFAULT_PROVIDER=lmstudio)
LMSTUDIO_HOST=http://localhost:1234/v1

# OpenRouter / OpenAI / Gemini API keys
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base

# Embeddings
EMBED_MODEL=nomic-embed-text
EMBED_CHUNK_SIZE=512
EMBED_CHUNK_OVERLAP=50

# Confluence (optional — only needed for Confluence push)
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_TOKEN=

# Jira (optional — only needed for Jira push)
JIRA_URL=https://your-org.atlassian.net
JIRA_TOKEN=
